# Flask
FLASK_SECRET_KEY=replace-with-a-long-random-string
# Set to "development" for local debugging (relaxes secure-cookie requirements).
FLASK_ENV=production

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://<your-domain>/auth/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Gunicorn / runtime tuning (optional)
# PORT=8000
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120

# Set to "0" to disable trusting X-Forwarded-* headers (default "1").
# TRUST_PROXY=1

# Deployment (used by the Traefik-based compose on the server: ${podName}, ${hostRule})
# podName should match the folder/stack name.
podName=preg
# VirtualHost address Traefik routes traffic to.
hostRule=preg.math.biu.ac.il
# Container time zone.
timeZone=Asia/Jerusalem
